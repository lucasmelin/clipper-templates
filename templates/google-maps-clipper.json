{
  "schemaVersion": "0.1.0",
  "name": "Google Maps",
  "behavior": "create",
  "noteContentFormat": "# {{selector:div[role=\"main\"]?aria-label}}",
  "properties": [
    {
      "name": "categories",
      "value": "[[Places]]",
      "type": "multitext"
    },
    {
      "name": "type",
      "value": "[[{{selector:button.DkEaL}}]]",
      "type": "multitext"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "address",
      "value": "{{selector:button[data-item-id=\\\"address\\\"]?aria-label|split:\\\"Address: \\\"|slice:1}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{selector:div[aria-label^=\\\"Information for\\\"] a[href*=\\\"http\\\"]?href|slice:0,1}}",
      "type": "text"
    },
    {
      "name": "rating",
      "value": "",
      "type": "number"
    },
    {
      "name": "scoreGoogle",
      "value": "{{selector:div[jsaction*=\\\"moreReviews\\\"] .fontDisplayLarge}}",
      "type": "number"
    },
    {
      "name": "created",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "last",
      "value": "",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "places, to-visit",
      "type": "multitext"
    },
    {
      "name": "latitude",
      "value": "{{url|split:\\\"/@\\\"|slice:1|split:\\\",\\\"|slice:0,1}}",
      "type": "text"
    },
    {
      "name": "longitude",
      "value": "{{url|split:\\\"/@\\\"|slice:1|split:\\\",\\\"|slice:1,2}}",
      "type": "text"
    }
  ],
  "triggers": ["https://www.google.com/maps/place/"],
  "noteNameFormat": "{{selector:div[role=\"main\"]?aria-label}}",
  "path": "04 - Resources/Clippings"
}
